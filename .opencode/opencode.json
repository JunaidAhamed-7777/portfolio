{
  "$schema": "https://opencode.ai/config.json",

  "username": "Junaid",
  "model": "anthropic/claude-sonnet-4-7-20250709",
  "small_model": "anthropic/claude-haiku-4-20250709",

  "logLevel": "INFO",
  "share": "manual",
  "autoupdate": true,
  "snapshot": true,

  "instructions": [
    "AGENTS.md",
    "README.md"
  ],

  "skills": {
    "paths": [".opencode/skills"]
  },

  "references": {
    "docs": {
      "path": "docs",
      "description": "Use for project documentation and conventions"
    }
  },

  "agent": {
    "build": {
      "mode": "subagent",
      "description": "Build expert: compiles, runs tests, and fixes build errors.",
      "permission": { "edit": "allow", "bash": { "npm *": "allow", "pnpm *": "allow", "yarn *": "allow", "*": "ask" } }
    },
    "plan": {
      "mode": "subagent",
      "description": "Planning expert: breaks down tasks into steps and tracks progress.",
      "permission": { "edit": "deny", "bash": "ask" }
    },
    "general": {
      "mode": "primary",
      "description": "General-purpose assistant for coding, research, and explanations."
    },
    "explore": {
      "mode": "subagent",
      "description": "Exploration expert: searches and summarizes large codebases quickly.",
      "permission": { "edit": "deny", "bash": "ask" }
    }
  },

  "command": {},

  "mcp": {},

  "plugin": [],

  "permission": {
    "edit": "ask",
    "bash": { "git *": "allow", "npm *": "allow", "pnpm *": "allow", "yarn *": "allow", "*": "ask" },
    "external_directory": { "*": "ask" }
  },

  "experimental": {
    "primary_tools": ["read", "edit", "bash"]
  },

  "tool_output": {
    "max_lines": 200,
    "max_bytes": 8192
  },

  "compaction": {
    "auto": true,
    "tail_turns": 15
  }
}
